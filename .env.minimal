# Configuration minimale pour développement
NODE_ENV=development
PORT=5000

# Supabase (remplacer par vos vraies clés)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk (remplacer par vos vraies clés)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ML Service
FLASK_ML_SERVICE_URL=http://localhost:5001
REDIS_URL=redis://localhost:6379

# Frontend
VITE_API_URL=http://localhost:5000
VITE_CLERK_PUBLIC_KEY=pk_test_your-clerk-publishable-key

# Services externes (optionnels pour le démarrage)
OPENAI_API_KEY=sk-your-openai-key
STRIPE_SECRET_KEY=sk_test_your-stripe-key
RESEND_API_KEY=re_your-resend-key
FROM_EMAIL=test@example.com
