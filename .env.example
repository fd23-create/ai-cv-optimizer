# AI CV Optimizer - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# FRONTEND (Vue.js)
# =============================================================================
VITE_API_URL=http://localhost:5000
VITE_CLERK_PUBLIC_KEY=your_clerk_publishable_key_here

# =============================================================================
# BACKEND (Node.js)
# =============================================================================
NODE_ENV=development
PORT=5000

# Database (Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Authentication (Clerk)
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
JWT_SECRET=your_jwt_secret_here_random_string

# External Services
FLASK_ML_SERVICE_URL=http://localhost:5001
REDIS_URL=redis://localhost:6379

# Storage (AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ai-cv-optimizer-storage

# Email Service
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@your-domain.com

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# ML SERVICE (Flask)
# =============================================================================
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# OpenAI API
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ML Configuration
MODEL_PATH=./models
SPACY_MODEL=en_core_web_sm
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Analysis Configuration
MAX_FILE_SIZE=10485760
SUPPORTED_LANGUAGES=en,fr,es,de,it,pt
DEFAULT_LANGUAGE=en

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION=30d

# =============================================================================
# DEVELOPMENT OPTIONS
# =============================================================================
# Enable debug logging
DEBUG=true
LOG_LEVEL=debug

# Enable hot reload
HOT_RELOAD=true

# Enable CORS for development
CORS_ORIGIN=http://localhost:3000

# =============================================================================
# PRODUCTION OPTIONS
# =============================================================================
# Set to "production" for production deployment
NODE_ENV=production
FLASK_ENV=production

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Domain Configuration
DOMAIN=your-domain.com
API_DOMAIN=api.your-domain.com

# =============================================================================
# SECURITY
# =============================================================================
# Session secrets (generate random strings)
SESSION_SECRET=your_session_secret_here
COOKIE_SECRET=your_cookie_secret_here

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================
# Enable monitoring (set to "true" to enable)
ENABLE_PROMETHEUS=false
ENABLE_GRAFANA=false
ENABLE_LOKI=false

# Enable SSL (set to "true" to enable HTTPS)
ENABLE_SSL=false

# Enable caching (set to "true" to enable Redis caching)
ENABLE_CACHE=true

# =============================================================================
# TESTING
# =============================================================================
# Test database
TEST_SUPABASE_URL=your_test_supabase_url
TEST_SUPABASE_ANON_KEY=your_test_supabase_anon_key

# Test email
TEST_EMAIL=test@example.com

# =============================================================================
# NOTES
# =============================================================================
# 1. Generate strong random secrets for production:
#    - JWT_SECRET
#    - SESSION_SECRET
#    - COOKIE_SECRET
#
# 2. Keep your API keys secure and never commit them to version control
#
# 3. Use different keys for development and production environments
#
# 4. For production, consider using a secrets management service
#
# 5. Review and update all default values before deployment
